# ===== VERCEL ENVIRONMENT VARIABLES (.env.example) =====
# Copy these values and set them in Vercel Dashboard → Settings → Environment Variables

# [CRITICAL] Session secret key — use for signing cookies
# IMPORTANT: Replace with a strong random value. Use this one or generate your own:
SESSION_SECRET_KEY=nWLAial9rLzBLJ8MtUrm3R3Vaxq34bwWkFBl3GR8L0Y

# [CRITICAL] Frontend origin(s) — prevent automatic logout
# IMPORTANT: Replace with your actual Vercel frontend URL (comma-separated if multiple)
# Example: https://mech-connect.vercel.app or https://your-custom-domain.com
FRONTEND_ORIGINS=https://your-frontend.vercel.app

# [CRITICAL] Database URL — persist data across redeploys
# IMPORTANT: SQLite does NOT work on Vercel (ephemeral filesystem)
# Use a managed Postgres/MySQL database instead
# Example PostgreSQL URL:
DATABASE_URL=postgresql://user:password@host:5432/database_name

# Session cookie settings (defaults are OK, but be explicit for production)
SESSION_COOKIE_SAMESITE=None
SESSION_COOKIE_SECURE=True

# Session lifetime (days)
SESSION_LIFETIME_DAYS=7

# [OPTIONAL] Default admin account
# If not set, defaults to: email=admin@mechconnect.local, password=Admin@1234
DEFAULT_ADMIN_EMAIL=admin@mechconnect.local
DEFAULT_ADMIN_PASSWORD=YourStrongAdminPassword123!

# [OPTIONAL] Session cookie domain (for subdomains)
# Leave blank if serving on a single domain
# Example: .yourdomain.com
# SESSION_COOKIE_DOMAIN=

# [OPTIONAL] Pusher credentials (for real-time chat/notifications)
# Leave blank if not using Pusher
# PUSHER_APP_ID=
# PUSHER_KEY=
# PUSHER_SECRET=
# PUSHER_CLUSTER=ap2
