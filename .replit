modules = ["nodejs-24", "python-3.11", "postgresql-16"]

[deployment]
router = "application"
deploymentTarget = "autoscale"
run = ["node", "--enable-source-maps", "artifacts/api-server/dist/index.mjs"]
build = ["bash", "-c", "pnpm install && pnpm --filter @workspace/mistrivai run build && pnpm --filter @workspace/api-server run build"]

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "MistriVai Flask Backend"

[[workflows.workflow]]
name = "MistriVai Flask Backend"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash scripts/start-all.sh"
waitForPort = 25062

[agent]
stack = "BEST_EFFORT_FALLBACK"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 5001
externalPort = 3001

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 25062
externalPort = 80

[userenv]

[userenv.shared]
DEFAULT_ADMIN_EMAIL = "admin@easymistri.login"
DEFAULT_ADMIN_PASSWORD = "Admin@1234"
DEFAULT_ADMIN_USERNAME = "admin"
DEFAULT_ADMIN_FULL_NAME = "Admin"
SESSION_SECRET_KEY = "ed3eebb26ca085209e3d052d907b8d992fa6e260dea88fd34ef88971462255b5"

[nix]
channel = "stable-25_05"
